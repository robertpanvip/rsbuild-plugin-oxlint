{
  "name": "rsbuild-plugin-lint",
  "version": "1.0.0",
  "description": "rsbuild-plugin-lint",
  "private": true,
  "workspaces": [
    "./packages/*"
  ],
  "homepage": "https://github.com/robertpanvip/rsbuild-plugin-lint.git",
  "repository": {
    "type": "git",
    "url": "https://github.com/robertpanvip/rsbuild-plugin-lint.git"
  },
  "bugs": {
    "url": "https://github.com/robertpanvip/rsbuild-plugin-lint/issues"
  },
  "author": "pan",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' build",
    "test": "pnpm -r --filter='./packages/*' test",
    "lint": "pnpm -r --filter='./packages/*' lint"
  },
  "packageManager": "pnpm@9.0.0"
}
